<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-feature
        android:name="android.hardware.sensor.accelerometer"
        android:required="true" />

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:networkSecurityConfig="@xml/network_security_config"
        android:usesCleartextTraffic="true"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.FisioAging">

        <activity
            android:name=".ui.historico.HistoricoTestesActivity"
            android:exported="false"
            android:label="Histórico de Testes" />
        <activity
            android:name=".ui.historico.ResultadoTesteActivity"
            android:exported="false"
            android:label="Detalhes do Teste" />
        <activity
            android:name=".ui.selecao.SelecaoTesteActivity"
            android:exported="false"
            android:label="@string/title_activity_selecao_teste"
            android:theme="@style/Theme.FisioAging" />
        <activity
            android:name=".ui.main.MainActivity"
            android:exported="true">
        </activity>
        <activity
            android:name=".ui.marcha.MarchaDetalhesActivity"
            android:label="Detalhes do Teste" />
        <activity
            android:name=".ui.marcha.MarchaExecucaoActivity"
            android:label="Teste em Andamento" />
        <activity
            android:name=".ui.sincronia.SincroniaActivity"
            android:label="Sincronizar Testes" />
        <activity
            android:name=".ui.utt.UttDetalhesActivity"
            android:label="Instruções UTT" />
        <activity
            android:name=".ui.utt.UttExecucaoActivity"
            android:label="Teste UTT" />
        <activity
            android:name=".ui.pacientes.ListaPacientesActivity"
            android:exported="false" />
        <activity
            android:name=".ui.login.LoginActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>