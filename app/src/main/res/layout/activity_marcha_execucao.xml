<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#FFFFFF"
    android:gravity="center_horizontal"
    tools:context=".TesteEmAndamentoActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/card_border_background"
        android:padding="20dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2 Minutos Marcha estacionária"
            android:textColor="@android:color/black"
            android:textSize="20sp"
            android:textStyle="bold" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="O paciente deve marchar no lugar por 2 minutos. Conte as repetições automaticamente usando os sensores."
            android:textColor="#555555"
            android:textSize="16sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="16dp"
        android:background="@drawable/card_border_background"
        android:paddingVertical="32dp"
        android:gravity="center">

        <TextView
            android:id="@+id/text_timer_contador"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2:00"
            android:textColor="@android:color/black"
            android:textSize="48sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/text_resultado_final"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 Repetições"
            android:textColor="#008000"
            android:textSize="40sp"
            android:textStyle="bold"
            android:visibility="gone"/> <TextView
        android:id="@+id/lbl_status_teste"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tempo Restante"
        android:textColor="#333333"
        android:textSize="18sp" />
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp">

        <LinearLayout
            android:id="@+id/layout_botao_play"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:visibility="gone">
            <ImageButton
                android:id="@+id/btn_play"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_play"
                android:background="@drawable/card_border_background"
                android:padding="16dp"
                android:contentDescription="Iniciar Teste" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layout_botoes_rodando"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:visibility="gone">
            <ImageButton
                android:id="@+id/btn_restart_rodando"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_restart"
                android:background="@drawable/card_border_background"
                android:padding="16dp"
                android:layout_marginEnd="16dp"
                android:contentDescription="Reiniciar Teste" />
            <ImageButton
                android:id="@+id/btn_stop"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_stop"
                android:background="@drawable/card_border_background"
                android:padding="16dp"
                android:layout_marginStart="16dp"
                android:contentDescription="Parar Teste" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layout_botoes_concluido"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:visibility="gone">
            <ImageButton
                android:id="@+id/btn_restart_concluido"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_restart"
                android:background="@drawable/card_border_background"
                android:padding="16dp"
                android:contentDescription="Reiniciar" />
            <ImageButton
                android:id="@+id/btn_discard"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_discard"
                android:background="@drawable/card_border_background"
                android:padding="16dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:contentDescription="Descartar" />
            <ImageButton
                android:id="@+id/btn_save"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_save"
                android:background="@drawable/card_border_background"
                android:padding="16dp"
                android:contentDescription="Salvar" />
        </LinearLayout>
    </FrameLayout>
</LinearLayout>