<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#FFFFFF"
    tools:context=".ui.marcha.MarchaDetalhesActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/card_border_background"
        android:padding="20dp">

        <TextView
            android:id="@+id/text_titulo_teste"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2 Minutos Marcha estacionária"
            android:textColor="@android:color/black"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/text_descricao_teste"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="O paciente deve marchar no lugar por 2 minutos."
            android:textColor="#555555"
            android:textSize="16sp" />

    </LinearLayout>

    <Button
        android:id="@+id/button_iniciar_teste"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:backgroundTint="@android:color/black"
        android:text="Iniciar Teste"
        android:textColor="@android:color/white"
        android:textSize="18sp"
        android:paddingVertical="12dp" />

</LinearLayout>